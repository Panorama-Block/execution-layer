{
  "openapi": "3.0.3",
  "info": {
    "title": "PanoramaBlock Execution Layer API",
    "description": "On-chain DeFi execution backend for Base. Prepares unsigned transaction bundles for swap, liquidity, and staking operations via Aerodrome Finance.\n\nContracts deployed on Base Mainnet:\n- **PanoramaExecutor**: `0x82b000512A19f7B762A23033aEA5AE00aBD0D2bC`\n- **AerodromeAdapter**: `0x187e499afB2DE75836800ad19147e0cFcd2Dc715`",
    "version": "1.0.0",
    "contact": {
      "name": "PanoramaBlock"
    }
  },
  "servers": [
    { "url": "http://localhost:3010", "description": "Local development" }
  ],
  "tags": [
    { "name": "Health", "description": "Service health check" },
    { "name": "DCA", "description": "Dollar-Cost Averaging — create/cancel orders, keeper endpoint" },
    { "name": "Swap", "description": "Swap module — quote, prepare bundle (approve + swap), list pairs" },
    { "name": "Staking", "description": "Liquid Staking module — enter/exit positions, claim rewards" },
    { "name": "Execution", "description": "Core execution — swaps, approvals, allowances, pools, quotes" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "execution-service" },
                    "port": { "type": "string", "example": "3010" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/staking/protocol-info": {
      "get": {
        "tags": ["Staking"],
        "summary": "Get protocol info (APY, TVL)",
        "description": "Returns Aerodrome protocol info with APR estimates and total staked per pool. Cached for 10 minutes.",
        "responses": {
          "200": {
            "description": "Protocol info with pool APR data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "protocol": { "type": "string" },
                    "chain": { "type": "string" },
                    "pools": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "poolId": { "type": "string" },
                          "poolName": { "type": "string" },
                          "poolAddress": { "type": "string" },
                          "gaugeAddress": { "type": "string" },
                          "stable": { "type": "boolean" },
                          "rewardRatePerSecond": { "type": "string" },
                          "totalStaked": { "type": "string" },
                          "estimatedAPR": { "type": "string" }
                        }
                      }
                    },
                    "updatedAt": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/staking/pools": {
      "get": {
        "tags": ["Staking"],
        "summary": "List available staking pools",
        "description": "Returns all enabled Aerodrome pools with on-chain data: pool address, gauge address, total staked, reward rate.",
        "responses": {
          "200": {
            "description": "List of pools",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pools": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/StakingPool" }
                    }
                  }
                },
                "example": {
                  "pools": [{
                    "id": "weth-usdc-volatile",
                    "name": "WETH/USDC Volatile",
                    "tokenA": { "symbol": "WETH", "address": "0x4200000000000000000000000000000000000006", "decimals": 18 },
                    "tokenB": { "symbol": "USDC", "address": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913", "decimals": 6 },
                    "stable": false,
                    "poolAddress": "0xcDAC0d6c6C59727a65F871236188350531885C43",
                    "gaugeAddress": "0x519BBD1Dd8C6A94C46080E24f316c14Ee758C025",
                    "gaugeAlive": true,
                    "rewardToken": { "symbol": "AERO", "address": "0x940181a94A35A4569E4529A3CDfB74e38FD98631", "decimals": 18 },
                    "totalStaked": "88416667562256151",
                    "rewardRate": "72092502098248363"
                  }]
                }
              }
            }
          }
        }
      }
    },
    "/staking/position/{userAddress}": {
      "get": {
        "tags": ["Staking"],
        "summary": "Get user staking positions",
        "description": "Returns all active staking positions (stakedBalance > 0) and earned rewards for a given user address.",
        "parameters": [
          {
            "name": "userAddress",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561"
          }
        ],
        "responses": {
          "200": {
            "description": "User positions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "positions": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Position" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/staking/portfolio/{userAddress}": {
      "get": {
        "tags": ["Staking"],
        "summary": "Get user portfolio",
        "description": "Returns full portfolio: wallet balances, LP positions with underlying token amounts, and pending rewards.",
        "parameters": [
          { "name": "userAddress", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Portfolio data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userAddress": { "type": "string" },
                    "totalPositions": { "type": "integer" },
                    "assets": { "type": "array", "items": { "type": "object" } },
                    "walletBalances": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/staking/transaction/submit": {
      "post": {
        "tags": ["Staking"],
        "summary": "Submit transaction hash for tracking",
        "description": "Submit a signed transaction hash to track its status. The backend will poll for confirmation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["txHash", "userAddress"],
                "properties": {
                  "txHash": { "type": "string" },
                  "userAddress": { "type": "string" },
                  "action": { "type": "string", "description": "Action label (e.g., enter-strategy)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Transaction registered for tracking" }
        }
      }
    },
    "/staking/transaction/{txHash}": {
      "get": {
        "tags": ["Staking"],
        "summary": "Get transaction status",
        "parameters": [
          { "name": "txHash", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Transaction status (pending/confirmed/failed)" },
          "404": { "description": "Transaction not found" }
        }
      }
    },
    "/staking/history/{userAddress}": {
      "get": {
        "tags": ["Staking"],
        "summary": "Get transaction history",
        "description": "Returns all tracked transactions for a user, sorted by most recent first.",
        "parameters": [
          { "name": "userAddress", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Transaction list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactions": { "type": "array", "items": { "type": "object" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/staking/prepare-enter": {
      "post": {
        "tags": ["Staking"],
        "summary": "Prepare enter staking strategy",
        "description": "Builds a TransactionBundle to enter a staking position: approve tokens → addLiquidity → approve LP → stake in gauge. Returns ordered unsigned transactions for the frontend to sign.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EnterStrategyRequest" },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "poolId": "weth-usdc-volatile",
                "amountA": "10000000000000000",
                "amountB": "10000000",
                "slippageBps": 100,
                "deadlineMinutes": 20
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction bundle ready to sign",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bundle": { "$ref": "#/components/schemas/TransactionBundle" },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "poolAddress": { "type": "string" },
                        "gaugeAddress": { "type": "string" },
                        "tokenA": { "$ref": "#/components/schemas/TokenInfo" },
                        "tokenB": { "$ref": "#/components/schemas/TokenInfo" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error (pool not found, gauge not found, etc.)" }
        }
      }
    },
    "/staking/prepare-exit": {
      "post": {
        "tags": ["Staking"],
        "summary": "Prepare exit staking strategy",
        "description": "Builds a TransactionBundle to exit a staking position: unstake from gauge → approve LP → removeLiquidity. Supports full or partial exit.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExitStrategyRequest" },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "poolId": "weth-usdc-volatile",
                "deadlineMinutes": 20
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction bundle ready to sign",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bundle": { "$ref": "#/components/schemas/TransactionBundle" },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "poolId": { "type": "string" },
                        "poolAddress": { "type": "string" },
                        "gaugeAddress": { "type": "string" },
                        "lpAmount": { "type": "string" },
                        "stable": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/staking/prepare-claim": {
      "post": {
        "tags": ["Staking"],
        "summary": "Prepare claim rewards",
        "description": "Prepares a single transaction to claim AERO rewards from a gauge. Called directly on the gauge (not through PanoramaExecutor).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ClaimRewardsRequest" },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "poolId": "weth-usdc-volatile"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Claim transaction ready to sign",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transaction": { "$ref": "#/components/schemas/PreparedTransaction" },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "poolId": { "type": "string" },
                        "gaugeAddress": { "type": "string" },
                        "earnedRewards": { "type": "string" },
                        "rewardToken": { "$ref": "#/components/schemas/TokenInfo" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error (no rewards, gauge not found, etc.)" }
        }
      }
    },
    "/dca/transaction/submit": {
      "post": {
        "tags": ["DCA"],
        "summary": "Submit DCA tx hash for tracking",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["txHash", "userAddress"], "properties": { "txHash": { "type": "string" }, "userAddress": { "type": "string" }, "action": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Transaction registered" } }
      }
    },
    "/dca/transaction/{txHash}": {
      "get": {
        "tags": ["DCA"],
        "summary": "Get DCA tx status",
        "parameters": [{ "name": "txHash", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Transaction status" }, "404": { "description": "Not found" } }
      }
    },
    "/dca/history/{userAddress}": {
      "get": {
        "tags": ["DCA"],
        "summary": "Get DCA transaction history",
        "parameters": [{ "name": "userAddress", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "DCA transaction list" } }
      }
    },
    "/dca/prepare-create": {
      "post": {
        "tags": ["DCA"],
        "summary": "Prepare create DCA order",
        "description": "Builds a TransactionBundle to create a DCA order: approve tokenIn (if needed) → createOrder on DCAVault. User deposits tokenIn into the vault; keeper will execute swaps at each interval.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PrepareCreateDCAOrderRequest" },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "tokenIn": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                "tokenOut": "0x4200000000000000000000000000000000000006",
                "amountPerSwap": "10000000",
                "intervalSeconds": 86400,
                "remainingSwaps": 30,
                "stable": false,
                "depositAmount": "300000000"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction bundle ready to sign",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bundle": { "$ref": "#/components/schemas/TransactionBundle" },
                    "metadata": { "$ref": "#/components/schemas/DCAOrderMetadata" }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/dca/prepare-cancel": {
      "post": {
        "tags": ["DCA"],
        "summary": "Prepare cancel DCA order",
        "description": "Builds a TransactionBundle to cancel an order and optionally withdraw remaining balance.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userAddress", "orderId"],
                "properties": {
                  "userAddress": { "type": "string" },
                  "orderId": { "type": "integer" },
                  "withdrawAfter": { "type": "boolean", "default": true, "description": "Include withdraw step after cancel" }
                }
              },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "orderId": 0,
                "withdrawAfter": true
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Cancel bundle ready to sign" },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Order not found or not owned by user" }
        }
      }
    },
    "/dca/orders/{userAddress}": {
      "get": {
        "tags": ["DCA"],
        "summary": "Get user DCA orders",
        "description": "Returns all DCA orders for a given user address with on-chain state.",
        "parameters": [
          {
            "name": "userAddress",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561"
          }
        ],
        "responses": {
          "200": {
            "description": "List of DCA orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": { "type": "array", "items": { "$ref": "#/components/schemas/DCAOrderInfo" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/dca/order/{orderId}": {
      "get": {
        "tags": ["DCA"],
        "summary": "Get single DCA order",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 0 }
        ],
        "responses": {
          "200": { "description": "Order data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DCAOrderInfo" } } } },
          "500": { "description": "Order not found" }
        }
      }
    },
    "/dca/executable": {
      "get": {
        "tags": ["DCA"],
        "summary": "Get executable orders (keeper endpoint)",
        "description": "Returns all orders currently ready to execute. Your keeper should poll this endpoint and call DCAVault.execute(orderId) for each result.",
        "parameters": [
          { "name": "upTo", "in": "query", "schema": { "type": "integer", "default": 100 }, "description": "Scan order IDs from 0 to upTo (exclusive)" }
        ],
        "responses": {
          "200": {
            "description": "Executable orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": { "type": "array", "items": { "$ref": "#/components/schemas/DCAOrderInfo" } },
                    "checkedUpTo": { "type": "integer" },
                    "timestamp": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/swap/transaction/submit": {
      "post": {
        "tags": ["Swap"],
        "summary": "Submit swap tx hash for tracking",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["txHash", "userAddress"], "properties": { "txHash": { "type": "string" }, "userAddress": { "type": "string" }, "action": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Transaction registered" } }
      }
    },
    "/swap/transaction/{txHash}": {
      "get": {
        "tags": ["Swap"],
        "summary": "Get swap tx status",
        "parameters": [{ "name": "txHash", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Transaction status" }, "404": { "description": "Not found" } }
      }
    },
    "/swap/history/{userAddress}": {
      "get": {
        "tags": ["Swap"],
        "summary": "Get swap transaction history",
        "parameters": [{ "name": "userAddress", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Swap transaction list" } }
      }
    },
    "/swap/pairs": {
      "get": {
        "tags": ["Swap"],
        "summary": "List available swap pairs",
        "description": "Returns all enabled token pairs with on-chain pool address and reserves.",
        "responses": {
          "200": {
            "description": "List of swap pairs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pairs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/SwapPairInfo" }
                    }
                  }
                },
                "example": {
                  "pairs": [{
                    "id": "weth-usdc-volatile",
                    "tokenIn": { "symbol": "WETH", "address": "0x4200000000000000000000000000000000000006", "decimals": 18 },
                    "tokenOut": { "symbol": "USDC", "address": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913", "decimals": 6 },
                    "stable": false,
                    "poolAddress": "0xcDAC0d6c6C59727a65F871236188350531885C43",
                    "reserve0": "12000000000000000000",
                    "reserve1": "30000000000"
                  }]
                }
              }
            }
          }
        }
      }
    },
    "/swap/quote": {
      "post": {
        "tags": ["Swap"],
        "summary": "Get swap quote",
        "description": "Returns estimated output amount, amountOutMin (with slippage) and exchange rate. Does not execute anything.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SwapQuoteRequest" },
              "example": {
                "tokenIn": "0x4200000000000000000000000000000000000006",
                "tokenOut": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                "amountIn": "10000000000000000",
                "stable": false,
                "slippageBps": 50
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SwapQuoteResponse" },
                "example": {
                  "tokenIn": "0x4200000000000000000000000000000000000006",
                  "tokenOut": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                  "amountIn": "10000000000000000",
                  "amountOut": "25123456",
                  "amountOutMin": "25061169",
                  "stable": false,
                  "slippageBps": 50,
                  "exchangeRate": "2512.34560000"
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/swap/prepare": {
      "post": {
        "tags": ["Swap"],
        "summary": "Prepare swap bundle",
        "description": "Builds a TransactionBundle to execute a swap: approve tokenIn (only if allowance is insufficient) → executeSwap via PanoramaExecutor. Returns ordered unsigned transactions for the frontend to sign.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PrepareSwapBundleRequest" },
              "example": {
                "userAddress": "0xd6F31c5e32EE78A257A32cB6469BaB3F9fbd7561",
                "tokenIn": "0x4200000000000000000000000000000000000006",
                "tokenOut": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                "amountIn": "10000000000000000",
                "stable": false,
                "slippageBps": 50,
                "deadlineMinutes": 20
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction bundle ready to sign",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bundle": { "$ref": "#/components/schemas/TransactionBundle" },
                    "metadata": { "$ref": "#/components/schemas/SwapMetadata" }
                  }
                },
                "example": {
                  "bundle": {
                    "steps": [
                      { "to": "0x4200...", "data": "0x095ea7b3...", "value": "0", "chainId": 8453, "description": "Approve token for swap" },
                      { "to": "0x79D671...", "data": "0x...", "value": "0", "chainId": 8453, "description": "Swap via Aerodrome" }
                    ],
                    "totalSteps": 2,
                    "summary": "Swap via Aerodrome (volatile pool)"
                  },
                  "metadata": {
                    "tokenIn": "0x4200000000000000000000000000000000000006",
                    "tokenOut": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                    "amountIn": "10000000000000000",
                    "amountOut": "25123456",
                    "amountOutMin": "25061169",
                    "stable": false,
                    "slippageBps": 50,
                    "priceImpact": "0.0124"
                  }
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/execution/prepare-swap": {
      "post": {
        "tags": ["Execution"],
        "summary": "Prepare a token swap",
        "description": "Prepares a swap transaction through PanoramaExecutor → AerodromeAdapter.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SwapRequest" },
              "example": {
                "tokenIn": "0x4200000000000000000000000000000000000006",
                "tokenOut": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                "amountIn": "10000000000000000",
                "slippageBps": 50,
                "stable": false
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Swap transaction prepared" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/execution/prepare-approve": {
      "post": {
        "tags": ["Execution"],
        "summary": "Prepare ERC-20 approval",
        "description": "Prepares an approve transaction for a given token and spender.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "spender", "amount"],
                "properties": {
                  "token": { "type": "string", "description": "ERC-20 token address" },
                  "spender": { "type": "string", "description": "Address to approve" },
                  "amount": { "type": "string", "description": "Amount in wei" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Approve transaction prepared" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/execution/check-allowance": {
      "post": {
        "tags": ["Execution"],
        "summary": "Check ERC-20 allowance",
        "description": "Queries the on-chain allowance for a token/owner/spender combination.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "owner", "spender"],
                "properties": {
                  "token": { "type": "string" },
                  "owner": { "type": "string" },
                  "spender": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allowance data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "owner": { "type": "string" },
                    "spender": { "type": "string" },
                    "allowance": { "type": "string" },
                    "isApproved": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/execution/pools": {
      "get": {
        "tags": ["Execution"],
        "summary": "List Aerodrome pools",
        "description": "Returns available Aerodrome pools with reserves and pricing data.",
        "responses": {
          "200": { "description": "Pool list" }
        }
      }
    },
    "/execution/quote": {
      "get": {
        "tags": ["Execution"],
        "summary": "Get swap quote",
        "description": "Returns estimated output amount for a swap without executing it.",
        "parameters": [
          { "name": "tokenIn", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "tokenOut", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "amountIn", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "stable", "in": "query", "schema": { "type": "boolean", "default": false } }
        ],
        "responses": {
          "200": { "description": "Quote data with estimated output" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PreparedTransaction": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "Contract address to call" },
          "data": { "type": "string", "description": "Encoded calldata" },
          "value": { "type": "string", "description": "ETH value in wei" },
          "chainId": { "type": "integer", "description": "Chain ID (8453 for Base)" },
          "description": { "type": "string", "description": "Human-readable step description" }
        }
      },
      "TransactionBundle": {
        "type": "object",
        "properties": {
          "steps": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PreparedTransaction" }
          },
          "totalSteps": { "type": "integer" },
          "summary": { "type": "string" }
        }
      },
      "TokenInfo": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "address": { "type": "string" },
          "decimals": { "type": "integer" }
        }
      },
      "StakingPool": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "tokenA": { "$ref": "#/components/schemas/TokenInfo" },
          "tokenB": { "$ref": "#/components/schemas/TokenInfo" },
          "stable": { "type": "boolean" },
          "poolAddress": { "type": "string" },
          "gaugeAddress": { "type": "string" },
          "gaugeAlive": { "type": "boolean" },
          "rewardToken": { "$ref": "#/components/schemas/TokenInfo" },
          "totalStaked": { "type": "string" },
          "rewardRate": { "type": "string" }
        }
      },
      "Position": {
        "type": "object",
        "properties": {
          "poolId": { "type": "string" },
          "poolName": { "type": "string" },
          "stakedBalance": { "type": "string" },
          "earnedRewards": { "type": "string" }
        }
      },
      "EnterStrategyRequest": {
        "type": "object",
        "required": ["userAddress", "poolId", "amountA", "amountB"],
        "properties": {
          "userAddress": { "type": "string", "description": "User wallet address" },
          "poolId": { "type": "string", "description": "Pool identifier (e.g., weth-usdc-volatile)" },
          "amountA": { "type": "string", "description": "Amount of tokenA in wei" },
          "amountB": { "type": "string", "description": "Amount of tokenB in smallest unit" },
          "slippageBps": { "type": "integer", "description": "Slippage tolerance in basis points (100 = 1%)", "default": 100 },
          "deadlineMinutes": { "type": "integer", "description": "Transaction deadline in minutes from now", "default": 20 }
        }
      },
      "ExitStrategyRequest": {
        "type": "object",
        "required": ["userAddress", "poolId"],
        "properties": {
          "userAddress": { "type": "string" },
          "poolId": { "type": "string" },
          "amount": { "type": "string", "description": "LP amount to exit in wei. Omit for full exit." },
          "deadlineMinutes": { "type": "integer", "default": 20 }
        }
      },
      "ClaimRewardsRequest": {
        "type": "object",
        "required": ["userAddress", "poolId"],
        "properties": {
          "userAddress": { "type": "string" },
          "poolId": { "type": "string" }
        }
      },
      "SwapRequest": {
        "type": "object",
        "required": ["tokenIn", "tokenOut", "amountIn"],
        "properties": {
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountIn": { "type": "string" },
          "slippageBps": { "type": "integer", "default": 50 },
          "stable": { "type": "boolean", "default": false }
        }
      },
      "SwapQuoteRequest": {
        "type": "object",
        "required": ["tokenIn", "tokenOut", "amountIn"],
        "properties": {
          "tokenIn": { "type": "string", "description": "Input token address" },
          "tokenOut": { "type": "string", "description": "Output token address" },
          "amountIn": { "type": "string", "description": "Amount in wei" },
          "stable": { "type": "boolean", "default": false, "description": "Use stable pool" },
          "slippageBps": { "type": "integer", "default": 50, "description": "Slippage in basis points (50 = 0.5%)" }
        }
      },
      "SwapQuoteResponse": {
        "type": "object",
        "properties": {
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountIn": { "type": "string" },
          "amountOut": { "type": "string" },
          "amountOutMin": { "type": "string", "description": "amountOut with slippage applied" },
          "stable": { "type": "boolean" },
          "slippageBps": { "type": "integer" },
          "exchangeRate": { "type": "string", "description": "amountOut / amountIn" }
        }
      },
      "PrepareSwapBundleRequest": {
        "type": "object",
        "required": ["userAddress", "tokenIn", "tokenOut", "amountIn"],
        "properties": {
          "userAddress": { "type": "string", "description": "User wallet address (for allowance check)" },
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountIn": { "type": "string", "description": "Amount in wei" },
          "stable": { "type": "boolean", "default": false },
          "slippageBps": { "type": "integer", "default": 50 },
          "deadlineMinutes": { "type": "integer", "default": 20 }
        }
      },
      "SwapMetadata": {
        "type": "object",
        "properties": {
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountIn": { "type": "string" },
          "amountOut": { "type": "string" },
          "amountOutMin": { "type": "string" },
          "stable": { "type": "boolean" },
          "slippageBps": { "type": "integer" },
          "priceImpact": { "type": "string", "description": "Estimated price impact in %" }
        }
      },
      "PrepareCreateDCAOrderRequest": {
        "type": "object",
        "required": ["userAddress", "tokenIn", "tokenOut", "amountPerSwap", "intervalSeconds", "depositAmount"],
        "properties": {
          "userAddress": { "type": "string" },
          "tokenIn": { "type": "string", "description": "Token to sell" },
          "tokenOut": { "type": "string", "description": "Token to buy" },
          "amountPerSwap": { "type": "string", "description": "Amount of tokenIn per execution (wei)" },
          "intervalSeconds": { "type": "integer", "description": "Seconds between executions (e.g. 86400 = daily)" },
          "remainingSwaps": { "type": "integer", "default": 0, "description": "Max executions. 0 = unlimited" },
          "stable": { "type": "boolean", "default": false },
          "depositAmount": { "type": "string", "description": "Total tokenIn to deposit into vault (wei)" }
        }
      },
      "DCAOrderMetadata": {
        "type": "object",
        "properties": {
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountPerSwap": { "type": "string" },
          "intervalSeconds": { "type": "integer" },
          "remainingSwaps": { "type": "integer" },
          "depositAmount": { "type": "string" },
          "stable": { "type": "boolean" },
          "estimatedExecutions": { "type": "integer" },
          "dcaVaultAddress": { "type": "string" }
        }
      },
      "DCAOrderInfo": {
        "type": "object",
        "properties": {
          "orderId": { "type": "integer" },
          "owner": { "type": "string" },
          "tokenIn": { "type": "string" },
          "tokenOut": { "type": "string" },
          "amountPerSwap": { "type": "string" },
          "interval": { "type": "integer" },
          "lastExecuted": { "type": "integer" },
          "nextExecutionAt": { "type": "integer" },
          "remainingSwaps": { "type": "integer" },
          "balance": { "type": "string" },
          "stable": { "type": "boolean" },
          "active": { "type": "boolean" },
          "executable": { "type": "boolean" }
        }
      },
      "SwapPairInfo": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tokenIn": { "$ref": "#/components/schemas/TokenInfo" },
          "tokenOut": { "$ref": "#/components/schemas/TokenInfo" },
          "stable": { "type": "boolean" },
          "poolAddress": { "type": "string" },
          "reserve0": { "type": "string" },
          "reserve1": { "type": "string" }
        }
      }
    }
  }
}
